{
  "name": "@verdigristech/design-tokens",
  "version": "0.8.0",
  "description": "Verdigris design system tokens — OKLch-first, multi-format output",
  "license": "UNLICENSED",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/VerdigrisTech/design.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "build/dist/index.js",
  "types": "build/dist/index.d.ts",
  "exports": {
    ".": "./build/dist/index.js",
    "./css/oklch": "./build/dist/css/oklch.css",
    "./css/hsl": "./build/dist/css/hsl.css",
    "./hex": "./build/dist/hex/colors.json",
    "./tailwind": "./build/dist/tailwind/preset.js",
    "./print/cover.css": "./build/print/cover.css",
    "./print/slides.css": "./build/print/slides.css",
    "./print/one-pager.css": "./build/print/one-pager.css",
    "./print/case-study.css": "./build/print/case-study.css",
    "./tokens/*": "./tokens/*",
    "./rules/*": "./rules/*",
    "./voice/recipes.yaml": "./voice/recipes.yaml",
    "./voice/ingredients.yaml": "./voice/ingredients.yaml",
    "./voice/feelings.yaml": "./voice/feelings.yaml",
    "./voice/USE.md": "./voice/USE.md",
    "./voice/README.md": "./voice/README.md"
  },
  "files": [
    "build/dist/",
    "build/print/",
    "tokens/",
    "rules/",
    "foundations/",
    "voice/recipes.yaml",
    "voice/ingredients.yaml",
    "voice/feelings.yaml",
    "voice/USE.md",
    "voice/README.md",
    "categories/",
    "workflows/",
    "LEARNINGS.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsx build/config.ts",
    "validate": "tsx build/validate.ts",
    "validate:rules": "tsx build/validate-rules.ts",
    "validate:all": "npm run validate && npm run validate:rules",
    "lint:external": "tsx build/lint-external.ts",
    "test:validators": "bash tests/validate-rules.test.sh",
    "test:package": "tsx build/test-package.ts",
    "test:browser": "playwright test",
    "test:browser:install": "playwright install --with-deps",
    "audit:cohesion": "tsx build/audit/cohesion.ts",
    "test:audit": "tsx build/audit/test-cohesion.ts",
    "audit:compliance": "tsx example_gen/compliance/cli.ts",
    "audit:compliance:smoke": "tsx example_gen/compliance/cli.ts --smoke",
    "test:compliance": "tsx example_gen/compliance/test-compliance.ts",
    "clean": "rm -rf build/dist _site test-results playwright-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/cheerio": "^0.22.35",
    "cheerio": "^1.2.0",
    "fast-glob": "^3.3.3",
    "http-server": "^14.1.1",
    "openai": "^6.36.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "yaml": "^2.8.4"
  }
}
