{
  "name": "@verdigristech/design-tokens",
  "version": "0.8.0",
  "description": "Verdigris design system tokens — OKLch-first, multi-format output",
  "license": "UNLICENSED",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/VerdigrisTech/design.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "build/dist/index.js",
  "types": "build/dist/index.d.ts",
  "exports": {
    ".": "./build/dist/index.js",
    "./css/oklch": "./build/dist/css/oklch.css",
    "./css/hsl": "./build/dist/css/hsl.css",
    "./hex": "./build/dist/hex/colors.json",
    "./tailwind": "./build/dist/tailwind/preset.js",
    "./print/cover.css": "./build/print/cover.css",
    "./print/slides.css": "./build/print/slides.css",
    "./print/one-pager.css": "./build/print/one-pager.css",
    "./print/case-study.css": "./build/print/case-study.css",
    "./tokens/*": "./tokens/*",
    "./rules/*": "./rules/*",
    "./voice/*": "./voice/*"
  },
  "files": [
    "build/dist/",
    "build/print/",
    "tokens/",
    "rules/",
    "foundations/",
    "voice/",
    "categories/",
    "workflows/",
    "LEARNINGS.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsx build/config.ts",
    "validate": "tsx build/validate.ts",
    "validate:rules": "tsx build/validate-rules.ts",
    "validate:all": "npm run validate && npm run validate:rules",
    "lint:external": "tsx build/lint-external.ts",
    "test:browser": "playwright test",
    "test:browser:install": "playwright install --with-deps",
    "clean": "rm -rf build/dist _site test-results playwright-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "http-server": "^14.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
